{
  "rewrites": [
    {
      "source": "/berita/:id",
      "missing": [
        {
          "type": "query",
          "key": "app"
        }
      ],
      "destination": "/api/article-og?id=:id"
    },
    {
      "source": "/((?!api|_next|.*\\..*).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ]
}